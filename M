from fastapi import FastAPI, Depends
from sqlalchemy.orm import Session
from database import engine, Base, get_db
from schemas import ApiResponse
from student_service import StudentService

Base.metadata.create_all(bind=engine)

app = FastAPI()

@app.get("/", response_model=ApiResponse)
def check_server():
    return {
        "message": "API đang chạy",
        "data": None
    }

@app.get("/students", response_model=ApiResponse)
def get_students(db: Session = Depends(get_db)):
    students = StudentService.get_all_students(db)
    return {
        "message": "Lấy danh sách sinh viên thành công",
        "data": students
    }

@app.get("/students/search", response_model=ApiResponse)
def search_students(class_name: str, db: Session = Depends(get_db)):
    students = StudentService.search_by_class(class_name, db)
    return {
        "message": f"Danh sách sinh viên lớp {class_name}",
        "data": students
    }

@app.get("/students/{student_id}", response_model=ApiResponse)
def get_student_detail(student_id: int, db: Session = Depends(get_db)):
    student = StudentService.get_student_by_id(student_id, db)
    return {
        "message": "Lấy chi tiết sinh viên thành công",
        "data": student
    }

@app.delete("/students/{student_id}", response_model=ApiResponse)
def delete_student(student_id: int, db: Session = Depends(get_db)):
    StudentService.delete_student(student_id, db)
    return {
        "message": "Xóa sinh viên thành công",
        "data": None
    }
