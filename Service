from sqlalchemy.orm import Session
from fastapi import HTTPException, status
from models import StudentModel

class StudentService:
    @staticmethod
    def get_all_students(db: Session):
        return db.query(StudentModel).all()

    @staticmethod
    def search_by_class(class_name: str, db: Session):
        return db.query(StudentModel).filter(StudentModel.class_name == class_name).all()

    @staticmethod
    def get_student_by_id(student_id: int, db: Session):
        student = db.query(StudentModel).filter(StudentModel.id == student_id).first()
        if not student:
            raise HTTPException(
                status_code=status.HTTP_404_NOT_FOUND,
                detail={"error": "Not found", "message": "không tìm thấy sinh viên"}
            )
        return student

    @staticmethod
    def delete_student(student_id: int, db: Session):
        student = db.query(StudentModel).filter(StudentModel.id == student_id).first()
        if not student:
            raise HTTPException(
                status_code=status.HTTP_404_NOT_FOUND,
                detail={"error": "Not found", "message": "không tìm thấy sinh viên"}
            )
        db.delete(student)
        db.commit()
        return None
