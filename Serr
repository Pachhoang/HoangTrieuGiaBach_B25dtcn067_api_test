from sqlalchemy.orm import Session, joinedload
from fastapi import HTTPException, status
from models.student import Student
from models.classroom import Classroom
from schemas.student import StudentCreate

class StudentService:
    @staticmethod
    def get_all_students(db: Session):
        return db.query(Student).options(joinedload(Student.classroom)).all()

    @staticmethod
    def create_student(db: Session, student_data: StudentCreate):
        # 1. Kiểm tra xem lớp học có tồn tại không
        classroom_exists = db.query(Classroom).filter(Classroom.id == student_data.class_id).first()
        if not classroom_exists:
            raise HTTPException(
                status_code=status.HTTP_404_NOT_FOUND,
                detail={
                    "statusCode": 404,
                    "message": "Không tìm thấy lớp học!",
                    "data": None,
                    "error": "ERR-CLASS-01",
                    "path": "/students"
                }
            )

        # 2. Kiểm tra xem student_code đã tồn tại chưa
        student_code_exists = db.query(Student).filter(Student.student_code == student_data.student_code).first()
        if student_code_exists:
            raise HTTPException(
                status_code=status.HTTP_400_BAD_REQUEST,
                detail={
                    "statusCode": 400,
                    "message": "Mã sinh viên đã tồn tại!",
                    "data": None,
                    "error": "ERR-STUDENT-01",
                    "path": "/students"
                }
            )

        # 3. Tạo sinh viên mới
        new_student = Student(
            student_code=student_data.student_code,
            full_name=student_data.full_name,
            email=student_data.email,
            class_id=student_data.class_id
        )

        db.add(new_student)
        db.commit()
        db.refresh(new_student)
        
        return new_student
