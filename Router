from fastapi import APIRouter, Depends, HTTPException, status
from sqlalchemy.orm import Session
from database import get_db
from schemas.student import StudentCreate, GetStudentsResponse, CreateStudentResponse
from services.student_service import StudentService

router = APIRouter(prefix="/students", tags=["Students"])

@router.get("", response_model=GetStudentsResponse)
def get_students(db: Session = Depends(get_db)):
    students = StudentService.get_all_students(db)
    return {
        "statusCode": 200,
        "message": "Lấy danh sách sinh viên thành công!",
        "data": students,
        "error": None,
        "path": "/students"
    }

@router.post("", response_model=CreateStudentResponse, status_code=status.HTTP_201_CREATED)
def create_student(student_data: StudentCreate, db: Session = Depends(get_db)):
    try:
        new_student = StudentService.create_student(db, student_data)
        return {
            "statusCode": 201,
            "message": "Thêm mới sinh viên thành công!",
            "data": new_student,
            "error": None,
            "path": "/students"
        }
    except HTTPException as ex:
        raise ex
    except Exception as e:
        raise HTTPException(
            status_code=500,
            detail={
                "statusCode": 500,
                "message": "Đã xảy ra lỗi hệ thống nghiêm trọng!",
                "data": None,
                "error": "INTERNAL_SERVER_ERROR",
                "path": "/students"
            }
        )
